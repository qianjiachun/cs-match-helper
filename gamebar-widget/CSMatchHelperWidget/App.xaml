<Application
    x:Class="CSMatchHelperWidget.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CSMatchHelperWidget">
    <Application.Resources>
        <Style x:Key="HudStatLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="#EBFFFFFF"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="VerticalAlignment" Value="Bottom"/>
            <Setter Property="CharacterSpacing" Value="50"/>
        </Style>
        <Style x:Key="HudStatLabelShadowStyle" TargetType="TextBlock" BasedOn="{StaticResource HudStatLabelStyle}">
            <Setter Property="Foreground" Value="#D9000000"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="1"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="HudStatValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#E6F8FAFC"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="VerticalAlignment" Value="Bottom"/>
        </Style>
        <Style x:Key="HudStatValueShadowStyle" TargetType="TextBlock" BasedOn="{StaticResource HudStatValueStyle}">
            <Setter Property="Foreground" Value="#BF000000"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="1"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="HudComboLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="CharacterSpacing" Value="80"/>
        </Style>
        <Style x:Key="HudComboLabelGlowStyle" TargetType="TextBlock" BasedOn="{StaticResource HudComboLabelStyle}">
            <Setter Property="Opacity" Value="0.45"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1.08" ScaleY="1.08"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="HudComboLabelShadowStyle" TargetType="TextBlock" BasedOn="{StaticResource HudComboLabelStyle}">
            <Setter Property="Foreground" Value="#A6000000"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="2"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="HudComboMetaStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#E0F8FAFC"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
        </Style>
        <Style x:Key="HudComboMetaShadowStyle" TargetType="TextBlock" BasedOn="{StaticResource HudComboMetaStyle}">
            <Setter Property="Foreground" Value="#B3000000"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="1"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
