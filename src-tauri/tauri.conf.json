{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CS匹配助手",
  "version": "2.2.0",
  "identifier": "com.csmatchhelper.desktop",
  "build": {
    "beforeDevCommand": "vite",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CS 匹配助手 -By 小淳",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 680,
        "decorations": false,
        "resizable": true,
        "center": true,
        "devtools": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      }
    }
  }
}
